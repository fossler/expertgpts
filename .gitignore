
# Ignore all __pycache__ directories and their contents everywhere
**/__pycache__/
**/__pycache__/*
__pycache__/

# Ignore all .pyc (python cache) files anywhere (if desired)
*.pyc

# Ignore virtual environment directories
venv/
env/
.virtualenv/
.venv/


# Log files
*log.*

# Ignore environment variable files
.env
.env.local
.env/
.env.*.local

# Ignore IDE specific files
.vscode/


# Ignore macOS specific files
.DS_Store

# Ignore Claude specific files
.claude_config.json
.claude/*
!.claude/skills/
!.claude/skills/**

# Streamlit - user-specific config files (not committed)
.streamlit/secrets.toml
.streamlit/app_defaults.toml
.streamlit/config.toml

# Testing
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Project specific - API keys and secrets
*.key
.secrets
credentials.json

# Auto-generated content
configs/
logs/
chat_history/
llm_comm/
streaming_cache/

# Expert pages only (not Home/Settings/Help which are permanent)
pages/*.py
!pages/1000_Home.py
!pages/9998_Settings.py
!pages/9999_Help.py

